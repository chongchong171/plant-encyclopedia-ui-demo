/**
 * 首页 UI Demo - 深墨绿 AI Native 风格
 */

/* 容器 */
.container {
  min-height: 100vh;
  background: #0D1F12;
  display: flex;
  flex-direction: column;
  position: relative;
}

/* 导航栏 */
.nav-bar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 40rpx 40rpx 20rpx;
}

.nav-title-text {
  font-size: 36rpx;
  font-weight: 600;
  color: #FFFFFF;
}

/* 大植物视觉区 */
.plant-visual {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 40rpx;
}

.plant-image-container {
  width: 100%;
  max-width: 600rpx;
  aspect-ratio: 1;
  border-radius: 40rpx;
  overflow: hidden;
  margin-bottom: 40rpx;
}

.plant-placeholder {
  width: 100%;
  height: 100%;
  background: linear-gradient(135deg, #1a3a2f 0%, #0D1F12 100%);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  color: #4CAF50;
}

.plant-placeholder-icon {
  font-size: 180rpx;
}

/* 植物信息 */
.plant-name {
  font-size: 44rpx;
  font-weight: 600;
  color: #FFFFFF;
  margin-bottom: 16rpx;
  text-align: center;
}

.plant-desc {
  font-size: 28rpx;
  color: #A8C5B0;
  text-align: center;
}

/* 主识别按钮 */
.identify-btn {
  width: 90%;
  height: 100rpx;
  background: linear-gradient(135deg, #4CAF50 0%, #66BB6A 100%);
  border-radius: 50rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
  margin: 30rpx auto;
  box-shadow: 0 8rpx 32rpx rgba(76, 175, 80, 0.3);
}

.identify-btn-text {
  font-size: 32rpx;
  font-weight: 600;
  color: #FFFFFF;
}

/* 功能网格 */
.func-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 20rpx;
  padding: 0 40rpx;
}

.func-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 24rpx 0;
  background: rgba(255, 255, 255, 0.05);
  border-radius: 20rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.1);
}

.func-icon {
  font-size: 44rpx;
  margin-bottom: 12rpx;
}

.func-name {
  font-size: 24rpx;
  color: #A8C5B0;
}

/* AI 悬浮按钮 */
.ai-float-btn {
  position: fixed;
  right: 40rpx;
  bottom: 200rpx;
  width: 140rpx;
  height: 140rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #4CAF50 0%, #00BCD4 100%);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  box-shadow: 0 12rpx 40rpx rgba(76, 175, 80, 0.4);
  z-index: 100;
  animation: pulse 2s ease-in-out infinite;
}

.ai-btn-icon {
  font-size: 56rpx;
}

.ai-btn-text {
  font-size: 20rpx;
  color: #FFFFFF;
}

@keyframes pulse {
  0%, 100% { transform: scale(1); }
  50% { transform: scale(1.05); }
}

/* 提醒卡片 */
.reminder-card {
  margin: 20rpx 40rpx;
  padding: 24rpx 30rpx;
  background: rgba(255, 215, 0, 0.1);
  border: 1rpx solid rgba(255, 215, 0, 0.3);
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.reminder-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #FFD700;
}