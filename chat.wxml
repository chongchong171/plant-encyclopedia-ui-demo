<!-- AI 对话页 UI Demo - 深墨绿 AI Native 风格 -->
<view class="chat-container">
  <!-- 顶部导航栏 -->
  <view class="chat-nav">
    <view style="display: flex; align-items: center; gap: 16rpx;">
      <text style="font-size: 44rpx; color: #A8C5B0;" bindtap="onBack">‹</text>
      <text class="chat-nav-title">AI 植物管家</text>
    </view>
    <text class="nav-action-btn" bindtap="onHistory">历史</text>
  </view>
  
  <!-- 消息列表 -->
  <scroll-view class="message-list" scroll-y>
    <!-- 欢迎消息 -->
    <view class="message ai">
      <view class="message-bubble">
        <text class="message-text">你好！我是你的植物管家 🌿</text>
      </view>
    </view>
    
    <view class="message ai">
      <view class="message-bubble">
        <text class="message-text">你可以说：</text>
        <text class="message-text">• "我买了一盆绿萝"</text>
        <text class="message-text">• "我的绿萝浇水了"</text>
        <text class="message-text">• "绿萝叶子黄了怎么办"</text>
      </view>
    </view>
    
    <!-- 消息列表 -->
    <view wx:for="{{messages}}" wx:key="id" class="message {{item.role}}">
      <view class="message-bubble">
        <text class="message-text">{{item.content}}</text>
      </view>
    </view>
    
    <!-- 确认卡片 -->
    <view wx:if="{{confirmCard}}" class="confirm-card">
      <view class="confirm-card-title">
        <text>🌿 {{confirmCard.title}}</text>
      </view>
      
      <view wx:for="{{confirmCard.fields}}" wx:key="label" class="confirm-card-field">
        <text class="field-label">{{item.label}}</text>
        <text class="field-value">{{item.value}}</text>
      </view>
      
      <view class="confirm-card-actions">
        <view class="btn-primary" bindtap="onConfirmSave">保存</view>
        <view class="btn-secondary" bindtap="onConfirmModify">修改</view>
      </view>
    </view>
    
    <!-- AI 正在输入 -->
    <view wx:if="{{isLoading}}" class="message ai">
      <view class="message-bubble">
        <view class="typing-indicator">
          <view class="typing-dot"></view>
          <view class="typing-dot"></view>
          <view class="typing-dot"></view>
        </view>
      </view>
    </view>
    
    <view id="bottom"></view>
  </scroll-view>
  
  <!-- 输入区域 -->
  <view class="input-area">
    <view class="input-btn" bindtap="onUploadImage">
      <text>📎</text>
    </view>
    
    <input 
      class="input-box" 
      placeholder="在这里输入..." 
      value="{{inputText}}" 
      bindinput="onInputChange"
      bindconfirm="onSend"
    />
    
    <view class="input-btn" bindtap="onVoiceInput">
      <text>🎤</text>
    </view>
    
    <view class="send-btn" bindtap="onSend">
      发送
    </view>
  </view>
</view>