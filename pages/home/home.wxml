<!-- 花草百科全书 - 首页（白色清爽风格） -->
<!-- 参考：白色背景 + 绿色点缀 + 大植物视觉 -->

<view class="container">
  <!-- 白色背景 -->
  <view class="bg-white"></view>
  
  <!-- 顶部区域：Logo + 植物图 -->
  <view class="header-section">
    <!-- 大植物视觉 -->
    <image class="plant-img" src="/images/monstera.png" mode="aspectFit"></image>
  </view>

  <!-- 品牌区域 -->
  <view class="brand-section">
    <text class="brand-name">花草百科全书</text>
    <text class="brand-slogan">拍一拍，认识你的植物</text>
  </view>

  <!-- 核心功能：大按钮 -->
  <view class="action-section">
    <view class="main-btn" bindtap="takePhoto">
      <view class="btn-icon-wrap">
        <text class="btn-icon">📷</text>
      </view>
      <view class="btn-content">
        <text class="btn-title">拍照识别</text>
        <text class="btn-desc">对准植物拍一拍</text>
      </view>
      <text class="btn-arrow">›</text>
    </view>
    
    <view class="main-btn secondary" bindtap="chooseFromAlbum">
      <view class="btn-icon-wrap light">
        <text class="btn-icon">🖼️</text>
      </view>
      <view class="btn-content">
        <text class="btn-title">相册上传</text>
        <text class="btn-desc">从相册选择植物照片</text>
      </view>
      <text class="btn-arrow">›</text>
    </view>
  </view>

  <!-- 快捷入口 -->
  <view class="quick-actions">
    <view class="quick-item" bindtap="goToMyPlants">
      <text class="quick-icon">🌱</text>
      <text class="quick-text">我的花园</text>
    </view>
    <view class="quick-item" bindtap="goToSearch">
      <text class="quick-icon">🔍</text>
      <text class="quick-text">搜索</text>
    </view>
    <view class="quick-item" bindtap="goToHistory">
      <text class="quick-icon">📋</text>
      <text class="quick-text">历史</text>
    </view>
    <view class="quick-item" bindtap="goToChat">
      <text class="quick-icon">💬</text>
      <text class="quick-text">AI助手</text>
    </view>
  </view>

  <!-- 底部装饰 -->
  <view class="footer-decor">
    <text class="footer-text">每一片叶子，都有它的故事</text>
  </view>
</view>