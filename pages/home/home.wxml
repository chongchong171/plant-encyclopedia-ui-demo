<!-- 花草百科全书 - 首页（墨绿引导页风格） -->
<!-- 参考：柠檬绿满屏首页 → 改为墨绿满屏 -->
<!-- 特色：大字Slogan + 右下角滑屏引导 -->

<view class="container" bindtouchstart="onTouchStart" bindtouchend="onTouchEnd">
  <!-- 墨绿满屏背景 -->
  <view class="bg-layer"></view>
  
  <!-- 植物装饰图（大视觉占主体） -->
  <view class="plant-visual">
    <image class="plant-img" src="/static/images/monstera.png" mode="aspectFit"></image>
  </view>

  <!-- Logo + Slogan 居中 -->
  <view class="brand-section">
    <text class="brand-name">花草百科全书</text>
    <text class="brand-slogan">拍一拍，花草百科全知道</text>
  </view>

  <!-- 核心功能入口（极简） -->
  <view class="action-bar">
    <view class="action-btn primary" bindtap="takePhoto">
      <text class="action-icon">📷</text>
      <text class="action-text">拍照识别</text>
    </view>
    <view class="action-btn secondary" bindtap="chooseFromAlbum">
      <text class="action-icon">🖼️</text>
      <text class="action-text">相册</text>
    </view>
  </view>

  <!-- 右下角滑屏引导 -->
  <view class="swipe-guide">
    <view class="swipe-arrow">
      <text class="arrow-icon">←</text>
      <text class="swipe-text">滑屏进入</text>
    </view>
    <view class="swipe-dots">
      <text class="dot active">●</text>
      <text class="dot">○</text>
      <text class="dot">○</text>
    </view>
  </view>

  <!-- AI 对话悬浮入口 -->
  <view class="ai-fab" bindtap="goToChat">
    <text class="ai-icon">💬</text>
  </view>
</view>