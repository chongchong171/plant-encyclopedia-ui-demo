<!-- 花草百科全书 - 首页（复刻 Motiff AI 设计） -->
<view class="page">
  <!-- 顶部品牌区 -->
  <view class="header">
    <view class="logo-area">
      <text class="logo-icon">🌿</text>
      <text class="logo-text">花草百科</text>
    </view>
    <text class="tagline">AI识别 · 养护指南</text>
  </view>

  <!-- 大植物视觉区 -->
  <view class="hero-visual">
    <image 
      class="plant-image" 
      src="/images/monstera.png" 
      mode="aspectFit"
      lazy-load="true"
      binderror="onImageError"
    ></image>
  </view>

  <!-- 主操作按钮 -->
  <view class="main-action">
    <view class="camera-btn" bindtap="takePhoto">
      <view class="camera-icon-wrap">
        <text class="camera-icon">📷</text>
      </view>
      <text class="camera-text">拍照识别</text>
    </view>
  </view>

  <!-- 功能入口网格 -->
  <view class="feature-grid">
    <view class="feature-item" bindtap="chooseFromAlbum">
      <view class="feature-icon album">
        <text class="icon">🖼️</text>
      </view>
      <text class="feature-name">相册识别</text>
    </view>
    
    <view class="feature-item" bindtap="goToSearch">
      <view class="feature-icon search">
        <text class="icon">🔍</text>
      </view>
      <text class="feature-name">植物搜索</text>
    </view>
    
    <view class="feature-item" bindtap="goToMyPlants">
      <view class="feature-icon garden">
        <text class="icon">🌱</text>
      </view>
      <text class="feature-name">我的花园</text>
    </view>
    
    <view class="feature-item" bindtap="goToChat">
      <view class="feature-icon ai">
        <text class="icon">🤖</text>
      </view>
      <text class="feature-name">AI助手</text>
    </view>
  </view>

  <!-- 底部提示 -->
  <view class="footer-tip">
    <text class="tip-text">左滑查看更多</text>
    <text class="tip-arrow">←</text>
  </view>
</view>