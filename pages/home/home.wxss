/* 花草百科全书 - 首页样式（墨绿引导页风格） */
/* 参考：柠檬绿满屏 → 墨绿满屏 */
/* 参考：大植物视觉 + 极简功能栏 */

/* ========== 容器 ========== */
.container {
  min-height: 100vh;
  background: #1a3a2f;  /* 墨绿满屏 */
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: space-between;
  padding: 40rpx 40rpx 60rpx;
  position: relative;
  overflow: hidden;
}

/* ========== 墨绿背景层 ========== */
.bg-layer {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: linear-gradient(180deg, #1a3a2f 0%, #27ae60 100%);
  opacity: 0.15;
}

/* ========== 植物大视觉（占主体 55%）========== */
.plant-visual {
  width: 100%;
  height: 55vh;
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1;
}

.plant-img {
  width: 85%;
  max-height: 55vh;
  opacity: 0.95;
}

/* ========== Logo + Slogan ========== */
.brand-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  z-index: 2;
  margin-bottom: 40rpx;
}

.brand-name {
  font-size: 44rpx;
  font-weight: bold;
  color: #ffffff;
  margin-bottom: 12rpx;
  letter-spacing: 2rpx;
}

.brand-slogan {
  font-size: 28rpx;
  color: #a8d5ba;  /* 浅绿 */
  letter-spacing: 4rpx;
}

/* ========== 底部功能栏（极简）========== */
.action-bar {
  display: flex;
  justify-content: center;
  gap: 30rpx;
  z-index: 2;
  margin-bottom: 20rpx;
}

.action-btn {
  display: flex;
  align-items: center;
  padding: 24rpx 40rpx;
  border-radius: 50rpx;
  background: rgba(255, 255, 255, 0.2);
}

.action-btn.primary {
  background: #27ae60;
  box-shadow: 0 8rpx 24rpx rgba(39, 174, 96, 0.4);
}

.action-btn.secondary {
  background: rgba(255, 255, 255, 0.15);
}

.action-icon {
  font-size: 36rpx;
  margin-right: 12rpx;
}

.action-text {
  font-size: 28rpx;
  color: #ffffff;
  font-weight: 600;
}

/* ========== 右下角滑屏引导 ========== */
.swipe-guide {
  position: absolute;
  right: 40rpx;
  bottom: 80rpx;
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  z-index: 3;
}

.swipe-arrow {
  display: flex;
  align-items: center;
  animation: swipeHint 1.5s ease-in-out infinite;
}

.arrow-icon {
  font-size: 32rpx;
  color: #a8d5ba;
  margin-right: 8rpx;
}

.swipe-text {
  font-size: 24rpx;
  color: #a8d5ba;
}

.swipe-dots {
  display: flex;
  gap: 8rpx;
  margin-top: 12rpx;
}

.dot {
  font-size: 20rpx;
  color: rgba(255, 255, 255, 0.3);
}

.dot.active {
  color: #27ae60;
}

/* ========== AI 对话悬浮按钮 ========== */
.ai-fab {
  position: absolute;
  left: 40rpx;
  bottom: 80rpx;
  width: 80rpx;
  height: 80rpx;
  background: #27ae60;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 24rpx rgba(39, 174, 96, 0.4);
  z-index: 3;
}

.ai-icon {
  font-size: 36rpx;
}

/* ========== 滑屏引导动画 ========== */
@keyframes swipeHint {
  0%, 100% {
    transform: translateX(0);
    opacity: 1;
  }
  50% {
    transform: translateX(-20rpx);
    opacity: 0.6;
  }
}