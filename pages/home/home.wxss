/* 花草百科全书 - 首页样式（复刻 Motiff AI 设计） */

/* ========== 页面容器 ========== */
.page {
  min-height: 100vh;
  background: #fafafa;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx 40rpx 60rpx;
}

/* ========== 顶部品牌区 ========== */
.header {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 40rpx;
}

.logo-area {
  display: flex;
  align-items: center;
  margin-bottom: 12rpx;
}

.logo-icon {
  font-size: 48rpx;
  margin-right: 12rpx;
}

.logo-text {
  font-size: 48rpx;
  font-weight: 700;
  color: #1a1a1a;
  letter-spacing: 4rpx;
}

.tagline {
  font-size: 24rpx;
  color: #4caf50;
  letter-spacing: 2rpx;
}

/* ========== 大植物视觉区 ========== */
.hero-visual {
  width: 100%;
  height: 380rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 40rpx;
}

.plant-image {
  width: 70%;
  max-height: 360rpx;
  filter: drop-shadow(0 20rpx 40rpx rgba(76, 175, 80, 0.15));
}

/* ========== 主操作按钮 ========== */
.main-action {
  width: 100%;
  display: flex;
  justify-content: center;
  margin-bottom: 50rpx;
}

.camera-btn {
  display: flex;
  align-items: center;
  background: linear-gradient(135deg, #4caf50 0%, #8bc34a 100%);
  padding: 28rpx 60rpx;
  border-radius: 50rpx;
  box-shadow: 0 12rpx 32rpx rgba(76, 175, 80, 0.35);
}

.camera-icon-wrap {
  width: 56rpx;
  height: 56rpx;
  background: rgba(255, 255, 255, 0.25);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 16rpx;
}

.camera-icon {
  font-size: 28rpx;
}

.camera-text {
  font-size: 32rpx;
  font-weight: 600;
  color: #ffffff;
  letter-spacing: 2rpx;
}

/* ========== 功能入口网格 ========== */
.feature-grid {
  width: 100%;
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 24rpx;
  margin-bottom: 40rpx;
}

.feature-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  background: #ffffff;
  border-radius: 24rpx;
  padding: 28rpx 16rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.04);
}

.feature-icon {
  width: 72rpx;
  height: 72rpx;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 12rpx;
}

.feature-icon.album {
  background: linear-gradient(135deg, #fff3e0 0%, #ffe0b2 100%);
}

.feature-icon.search {
  background: linear-gradient(135deg, #e3f2fd 0%, #bbdefb 100%);
}

.feature-icon.garden {
  background: linear-gradient(135deg, #e8f5e9 0%, #c8e6c9 100%);
}

.feature-icon.ai {
  background: linear-gradient(135deg, #f3e5f5 0%, #e1bee7 100%);
}

.icon {
  font-size: 32rpx;
}

.feature-name {
  font-size: 24rpx;
  color: #333;
  font-weight: 500;
}

/* ========== 底部提示 ========== */
.footer-tip {
  display: flex;
  align-items: center;
  opacity: 0.5;
  margin-top: auto;
}

.tip-text {
  font-size: 22rpx;
  color: #999;
}

.tip-arrow {
  font-size: 24rpx;
  color: #999;
  margin-left: 8rpx;
  animation: swipeHint 1.5s ease-in-out infinite;
}

@keyframes swipeHint {
  0%, 100% {
    transform: translateX(0);
  }
  50% {
    transform: translateX(-12rpx);
  }
}