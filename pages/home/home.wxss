/* 花草百科全书 - 首页样式（科技感设计） */
/* 核心：渐变 + 圆角 + 阴影 + 留白 */

/* ========== 容器 ========== */
.container {
  min-height: 100vh;
  position: relative;
  overflow: hidden;
}

/* ========== 渐变背景 ========== */
.gradient-bg {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: linear-gradient(160deg, #e8f5e9 0%, #ffffff 30%, #f3e5f5 70%, #e3f2fd 100%);
  z-index: 0;
}

/* ========== 主内容 ========== */
.main-content {
  position: relative;
  z-index: 1;
  padding: 60rpx 40rpx 40rpx;
  min-height: 100vh;
  display: flex;
  flex-direction: column;
}

/* ========== Hero 区域 ========== */
.hero-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 40rpx;
}

.brand {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 30rpx;
}

.brand-name {
  font-size: 48rpx;
  font-weight: 700;
  background: linear-gradient(135deg, #2e7d32 0%, #1565c0 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
  letter-spacing: 2rpx;
}

.brand-slogan {
  font-size: 24rpx;
  color: #78909c;
  margin-top: 8rpx;
  letter-spacing: 4rpx;
}

.plant-visual {
  width: 60%;
  max-height: 32vh;
  filter: drop-shadow(0 20rpx 40rpx rgba(46, 125, 50, 0.2));
}

/* ========== 功能卡片 ========== */
.feature-card {
  background: #ffffff;
  border-radius: 32rpx;
  padding: 36rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 8rpx 40rpx rgba(0, 0, 0, 0.06);
}

.card-header {
  margin-bottom: 28rpx;
}

.card-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #1a1a1a;
}

.card-subtitle {
  font-size: 22rpx;
  color: #90a4ae;
  margin-left: 12rpx;
}

.action-buttons {
  display: flex;
  gap: 20rpx;
}

.action-btn {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 28rpx 20rpx;
  background: #f5f7fa;
  border-radius: 24rpx;
  transition: all 0.3s;
}

.action-btn.primary {
  background: linear-gradient(135deg, #43a047 0%, #66bb6a 100%);
}

.btn-icon-bg {
  width: 72rpx;
  height: 72rpx;
  background: linear-gradient(135deg, #43a047 0%, #66bb6a 100%);
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 12rpx;
  box-shadow: 0 8rpx 20rpx rgba(67, 160, 71, 0.3);
}

.btn-icon-bg.outline {
  background: #ffffff;
  border: 2rpx solid #e0e0e0;
  box-shadow: none;
}

.btn-icon {
  font-size: 32rpx;
}

.btn-label {
  font-size: 26rpx;
  font-weight: 500;
  color: #333;
}

.action-btn.primary .btn-label {
  color: #ffffff;
}

/* ========== 快捷功能网格 ========== */
.quick-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 16rpx;
  margin-bottom: 30rpx;
}

.quick-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  background: #ffffff;
  border-radius: 20rpx;
  padding: 24rpx 12rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.04);
}

.quick-icon-bg {
  width: 64rpx;
  height: 64rpx;
  border-radius: 18rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 10rpx;
}

.quick-icon-bg.green {
  background: linear-gradient(135deg, #e8f5e9 0%, #c8e6c9 100%);
}

.quick-icon-bg.blue {
  background: linear-gradient(135deg, #e3f2fd 0%, #bbdefb 100%);
}

.quick-icon-bg.purple {
  background: linear-gradient(135deg, #f3e5f5 0%, #e1bee7 100%);
}

.quick-icon-bg.orange {
  background: linear-gradient(135deg, #fff3e0 0%, #ffe0b2 100%);
}

.quick-icon {
  font-size: 28rpx;
}

.quick-title {
  font-size: 22rpx;
  color: #333;
  font-weight: 500;
}

.quick-count {
  font-size: 18rpx;
  color: #f44336;
  margin-top: 4rpx;
}

/* ========== 底部提示 ========== */
.footer-hint {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 20rpx 0;
  opacity: 0.6;
}

.hint-text {
  font-size: 22rpx;
  color: #90a4ae;
}

.hint-arrow {
  font-size: 24rpx;
  color: #90a4ae;
  margin-left: 8rpx;
  animation: swipeHint 1.5s ease-in-out infinite;
}

@keyframes swipeHint {
  0%, 100% {
    transform: translateX(0);
  }
  50% {
    transform: translateX(-16rpx);
  }
}