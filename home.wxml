<!--首页 UI Demo - 深墨绿 AI Native 风格 -->
<view class="container">
  <!-- 顶部导航栏 -->
  <view class="nav-bar">
    <view>
      <text class="nav-title-text">🌿 植物管家</text>
    </view>
    <text>⚙️</text>
  </view>
  
  <!-- 大植物视觉区 -->
  <view class="plant-visual">
    <view class="plant-image-container">
      <view class="plant-placeholder">
        <text class="plant-placeholder-icon">🌱</text>
        <text style="font-size: 28rpx; color: #A8C5B0;">添加你的第一盆植物</text>
      </view>
    </view>
    
    <text class="plant-name" wx:if="{{plantName}}">{{plantName}}</text>
    <text class="plant-desc">{{plantDesc || '养护中，状态良好'}}</text>
  </view>
  
  <!-- 提醒卡片 -->
  <view class="reminder-card" wx:if="{{todayWaterCount > 0}}">
    <view style="display: flex; align-items: center; gap: 20rpx;">
      <text>💧</text>
      <view>
        <text class="reminder-title">今天需要浇水</text>
        <text style="font-size: 24rpx; color: #A8C5B0;">{{todayWaterPlantsStr}}</text>
      </view>
    </view>
    <text style="color: #FFD700;">›</text>
  </view>
  
  <!-- 主识别按钮 -->
  <view class="identify-btn" bindtap="onIdentify">
    <text>📷</text>
    <text class="identify-btn-text">拍照识别</text>
  </view>
  
  <!-- 功能网格 -->
  <view class="func-grid">
    <view class="func-item" bindtap="onAlbum">
      <text class="func-icon">🖼️</text>
      <text class="func-name">相册</text>
    </view>
    <view class="func-item" bindtap="onGarden">
      <text class="func-icon">🌱</text>
      <text class="func-name">花园</text>
    </view>
    <view class="func-item" bindtap="onDiagnosis">
      <text class="func-icon">🔍</text>
      <text class="func-name">诊断</text>
    </view>
    <view class="func-item" bindtap="onSearch">
      <text class="func-icon">🔎</text>
      <text class="func-name">搜索</text>
    </view>
  </view>
  
  <!-- AI 悬浮按钮 -->
  <view class="ai-float-btn" bindtap="goToChat">
    <text class="ai-btn-icon">🤖</text>
    <text class="ai-btn-text">AI</text>
  </view>
</view>